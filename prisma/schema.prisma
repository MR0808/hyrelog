generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

//
// -----------------------------
// Enums
// -----------------------------
enum CompanyRole {
  OWNER
  ADMIN
  BILLING
  AUDITOR
  MEMBER
}

enum WorkspaceRole {
  ADMIN
  DEVELOPER
  VIEWER
}

enum PlanTier {
  FREE
  STARTER
  GROWTH
  SCALE
  ENTERPRISE
}

enum MeterType {
  EVENTS
  WORKSPACES
  USERS
  EXPORTS
}

enum BillingInterval {
  MONTHLY
  YEARLY
}

enum SubscriptionStatus {
  INCOMPLETE
  INCOMPLETE_EXPIRED
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  UNPAID
}

enum ApiKeyScope {
  COMPANY
  WORKSPACE
}

//
// -----------------------------
// Auth (Next.js)
// -----------------------------
model User {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  email         String  @unique
  emailVerified Boolean @default(false)
  name          String?
  image         String?

  passwordHash String?

  accounts      Account[]
  sessions      Session[]
  verifications Verification[]

  companyUsers   CompanyUser[]
  workspaceUsers WorkspaceUser[]
}

model Account {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId                String
  providerId            String
  accountId             String
  accessToken           String?
  refreshToken          String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  idToken               String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerId, accountId])
  @@index([userId])
}

model Session {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId    String
  token     String   @unique
  expiresAt DateTime
  userAgent String?
  ipAddress String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Verification {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  identifier String
  value      String
  expiresAt  DateTime

  userId String?
  user   User?   @relation(fields: [userId], references: [id])
}

//
// -----------------------------
// Plans / Add-ons
// -----------------------------
model Plan {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  name        String
  slug        String  @unique
  description String?

  eventsPerMonth    Int
  exportsPerMonth   Int
  retentionDays     Int
  priceMonthlyCents Int
  priceYearlyCents  Int

  companies Company[]
}

model AddOn {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now())

  name        String
  slug        String  @unique
  description String?

  extraEventsPerMonth  Int @default(0)
  extraExportsPerMonth Int @default(0)
  priceMonthlyCents    Int

  companyAddOns CompanyAddOn[]
}

model CompanyAddOn {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now())

  companyId String
  addOnId   String
  active    Boolean @default(true)

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  addOn   AddOn   @relation(fields: [addOnId], references: [id], onDelete: Cascade)

  @@unique([companyId, addOnId])
}

//
// -----------------------------
// Core: Company / Workspace / Event / ApiKey
// -----------------------------
model Company {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now())

  name String
  slug String @unique

  planTier        PlanTier        @default(FREE)
  planId          String?
  plan            Plan?           @relation(fields: [planId], references: [id])
  billingInterval BillingInterval @default(MONTHLY)

  eventsPerMonth     Int     @default(50000)
  exportsPerMonth    Int     @default(0)
  retentionDays      Int     @default(7)
  unlimitedRetention Boolean @default(false)

  eventsWarningPercent   Int?
  eventsWarningAbsolute  Int?
  exportsWarningPercent  Int?
  exportsWarningAbsolute Int?

  webhookUrl    String?
  webhookSecret String?

  stripeCustomerId String?

  workspaces             Workspace[]
  companyUsers           CompanyUser[]
  subscriptions          StripeSubscription[]
  apiKeys                ApiKey[]
  companyAddOns          CompanyAddOn[]
  apiKeyLogs             ApiKeyLog[]
  usageStatsCompanies    UsageStatsCompany[]
  usageStatsWorkspaces   UsageStatsWorkspace[]
  billingMeterCompanies  BillingMeterCompany[]
  billingMeterWorkspaces BillingMeterWorkspace[]
  webhookDeliveries      WebhookDelivery[]
}

model Workspace {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now())

  name String
  slug String @unique

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  events  Event[]
  apiKeys ApiKey[]

  workspaceUsers         WorkspaceUser[]
  subscriptions          StripeSubscription[]
  apiKeyLogs             ApiKeyLog[]
  usageStatsWorkspaces   UsageStatsWorkspace[]
  billingMeterWorkspaces BillingMeterWorkspace[]

  @@index([companyId])
}

model Event {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  timestamp DateTime @default(now())

  workspaceId String

  type       String
  actorId    String?
  actorType  String?
  actorName  String?
  actorEmail String?

  sourceIp  String?
  userAgent String?

  metadata Json?
  before   Json?
  after    Json?

  chainId  String
  hash     String
  prevHash String?

  workspace         Workspace         @relation(fields: [workspaceId], references: [id])
  webhookDeliveries WebhookDelivery[]

  @@index([workspaceId, timestamp])
  @@index([workspaceId, type])
  @@index([workspaceId, actorId])
  @@index([chainId])
}

model ApiKey {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now())

  name  String
  scope ApiKeyScope @default(WORKSPACE)

  keyPrefix String @unique
  hashedKey String

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  workspaceId String?
  workspace   Workspace? @relation(fields: [workspaceId], references: [id])

  lastUsedAt DateTime?
  revoked    Boolean   @default(false)

  logs ApiKeyLog[]
}

model ApiKeyLog {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  apiKeyId    String
  companyId   String
  workspaceId String?

  method     String
  path       String
  statusCode Int
  durationMs Int?

  ip        String?
  userAgent String?

  apiKey    ApiKey     @relation(fields: [apiKeyId], references: [id], onDelete: Cascade)
  company   Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  workspace Workspace? @relation(fields: [workspaceId], references: [id])

  @@index([apiKeyId])
  @@index([companyId])
  @@index([workspaceId])
}

//
// -----------------------------
// RBAC
// -----------------------------
model CompanyUser {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now())

  companyId String
  userId    String
  role      CompanyRole @default(MEMBER)

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([companyId, userId])
  @@index([userId])
}

model WorkspaceUser {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now())

  workspaceId String
  userId      String
  role        WorkspaceRole @default(VIEWER)

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@index([userId])
}

//
// -----------------------------
// Usage (Company & Workspace)
// -----------------------------
model UsageStatsCompany {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  companyId String
  date      DateTime

  eventsIngested Int @default(0)
  eventsStored   Int @default(0)
  exportsRun     Int @default(0)
  activeApiKeys  Int @default(0)
  seats          Int @default(0)

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, date])
}

model UsageStatsWorkspace {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  companyId   String
  workspaceId String
  date        DateTime

  eventsIngested Int @default(0)
  eventsStored   Int @default(0)
  exportsRun     Int @default(0)

  company   Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([companyId, workspaceId, date])
}

//
// -----------------------------
// Billing Meters
// -----------------------------
model BillingMeterCompany {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now())

  companyId   String
  meterType   MeterType
  periodStart DateTime
  periodEnd   DateTime

  currentValue    Int       @default(0)
  softThreshold   Int?
  hardCap         Boolean   @default(true)
  unitSize        Int       @default(100000)
  unitPrice       Float     @default(0)
  lastIncrementAt DateTime?

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, meterType, periodStart])
}

model BillingMeterWorkspace {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now())

  companyId   String
  workspaceId String
  meterType   MeterType

  periodStart DateTime
  periodEnd   DateTime

  currentValue    Int       @default(0)
  softThreshold   Int?
  hardCap         Boolean   @default(true)
  unitSize        Int       @default(100000)
  unitPrice       Float     @default(0)
  lastIncrementAt DateTime?

  company   Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([companyId, workspaceId, meterType, periodStart])
}

//
// -----------------------------
// Stripe (Dashboard)
// -----------------------------
model StripeSubscription {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now())

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  stripeCustomerId     String
  stripeSubscriptionId String             @unique
  status               SubscriptionStatus
  currentPeriodStart   DateTime
  currentPeriodEnd     DateTime
  cancelAtPeriodEnd    Boolean            @default(false)
  canceledAt           DateTime?

  planTier        PlanTier
  billingInterval BillingInterval

  items       StripeSubscriptionItem[]
  workspace   Workspace?               @relation(fields: [workspaceId], references: [id])
  workspaceId String?

  @@index([companyId])
}

model StripeSubscriptionItem {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now())

  subscriptionId String
  subscription   StripeSubscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  stripePriceId            String
  stripeSubscriptionItemId String @unique
  quantity                 Int

  @@index([subscriptionId])
}

//
// -----------------------------
// Webhook Delivery
// -----------------------------
model WebhookDelivery {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  eventId String?
  event   Event?  @relation(fields: [eventId], references: [id])

  url           String
  status        String // SUCCESS | FAILED | PENDING | RETRY
  attempts      Int       @default(0)
  lastError     String?
  nextAttemptAt DateTime?

  payload Json?

  @@index([companyId])
  @@index([eventId])
}
