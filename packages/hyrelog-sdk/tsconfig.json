{
    "extends": "../../tsconfig.json",
    "compilerOptions": {
        "rootDir": "./src", // FIX: make sdk/src the root
        "outDir": "./dist", // FIX: output only inside package
        "declaration": true,
        "declarationMap": true,
        "module": "ESNext",
        "moduleResolution": "node",
        "target": "ES2020",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "resolveJsonModule": true,
        "allowSyntheticDefaultImports": true,
        "isolatedModules": false
    },
    "include": ["src/**/*"],
    "exclude": ["dist", "node_modules"]
}
